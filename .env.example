# Path to this repo on the server that runs sync-domains.sh
REPO_DIR=/opt/domain_list_for_router

# Git
GIT_BRANCH=main
CHECK_INTERVAL=60

# Keenetic (SSH: копирование файлов и CLI)
ROUTER_HOST=192.168.1.1
ROUTER_USER=admin
ROUTER_PASSWORD=change-me
REMOTE_REPO_DIR=/opt/domain_list_for_router

# VPN interface for new lists (dns-proxy route)
ROUTER_DNS_ROUTE_INTERFACE=Wireguard0
